import os
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns

# Configuración de estilo premium tipo startup / consultora
sns.set_theme(style="whitegrid")
plt.rcParams.update({
    'font.size': 12,
    'axes.labelsize': 14,
    'axes.titlesize': 16,
    'xtick.labelsize': 12,
    'ytick.labelsize': 12,
    'figure.titlesize': 18,
    'font.family': 'sans-serif'
})

# Definición de paleta de colores corporativa (Azul tecnológico, Gris elegante, Coral de acento)
PALETA_DATATALENT = ["#1A365D", "#2B6CB0", "#4299E1", "#ED8936", "#A0AEC0"]
sns.set_palette(PALETA_DATATALENT)

def cargar_datos(ruta_csv="../data/clean/dataset_limpio.csv"):
    """Carga el dataset unificado y limpio por Ele (Persona 3)."""
    if os.path.exists(ruta_csv):
        print(f"✅ Cargando datos limpios desde: {ruta_csv}")
        return pd.read_csv(ruta_csv)
    else:
        # Generar datos simulados realistas en caso de que aún no esté disponible el CSV de Ele
        print("⚠️ dataset_limpio.csv no encontrado en la ruta. Generando datos de prueba realistas...")
        np.random.seed(42)
        n_muestras = 300
        roles = ['Data Analyst', 'Data Scientist', 'Data Engineer', 'BI Analyst', 'Machine Learning Engineer']
        ciudades = ['Madrid', 'Barcelona', 'Remoto', 'Valencia', 'Sevilla']
        modalidades = ['Presencial', 'Híbrido', 'Remoto']
        skills_pool = ['Python', 'SQL', 'Power BI', 'AWS', 'Excel', 'Tableau', 'Spark', 'Databricks', 'Docker', 'Git']
        
        datos = {
            'title': np.random.choice(roles, n_muestras, p=[0.35, 0.25, 0.20, 0.12, 0.08]),
            'city': np.random.choice(ciudades, n_muestras, p=[0.40, 0.30, 0.15, 0.10, 0.05]),
            'salary': np.random.normal(loc=38000, scale=12000, size=n_muestras).astype(int),
            'experience_years': np.random.randint(0, 10, size=n_muestras),
            'remote_modality': np.random.choice(modalidades, n_muestras, p=[0.20, 0.50, 0.30]),
            'description': ["Ejemplo de vacante con requisitos en tecnología." for _ in range(n_muestras)]
        }
        # Asegurar salarios mínimos lógicos en España
        df = pd.DataFrame(datos)
        df['salary'] = df['salary'].apply(lambda x: max(18000, x))
        # Crear columnas simuladas de skills detectadas (One-Hot Encoding para simular extracción de descripciones)
        for skill in skills_pool:
            df[skill] = np.random.choice([0, 1], n_muestras, p=[0.7, 0.3])
        return df

def asegurar_carpeta_imagenes():
    """Garantiza la existencia del directorio images/ para exportar los gráficos."""
    os.makedirs("../images", exist_ok=True)
    print("📁 Carpeta 'images/' verificada/creada con éxito.")

# ==============================================================================
# GRÁFICO 1: TOP SKILLS MÁS DEMANDADAS (grafico_skills.png)
# ==============================================================================
def generar_grafico_skills(df):
    plt.figure(figsize=(10, 6))
    
    # Suponiendo que las skills están en columnas booleanas (1 si existe, 0 si no)
    skills_list = ['Python', 'SQL', 'Power BI', 'AWS', 'Excel', 'Tableau', 'Spark', 'Databricks', 'Docker', 'Git']
    # Filtrar solo las columnas que existan en el DataFrame real
    skills_existentes = [s for s in skills_list if s in df.columns]
    
    if len(skills_existentes) > 0:
        skills_freq = df[skills_existentes].sum().sort_values(ascending=False)
        # Convertir a porcentaje sobre el total de ofertas
        skills_pct = (skills_freq / len(df)) * 100
        
        sns.barplot(x=skills_pct.values, y=skills_pct.index, palette="Blues_r")
        plt.title("Habilidades Técnicas más Demandadas en Roles de Datos en España", pad=15)
        plt.xlabel("Porcentaje de Ofertas que la Requieren (%)")
        plt.ylabel("Habilidad / Herramienta")
        plt.xlim(0, 100)
        
        # Añadir etiquetas de datos en las barras
        for idx, value in enumerate(skills_pct.values):
            plt.text(value + 1, idx, f"{value:.1f}%", va='center', fontweight='bold', color="#1A365D")
            
        plt.tight_layout()
        plt.savefig("../images/grafico_skills.png", dpi=300)
        print("💾 Gráfico 'grafico_skills.png' guardado con éxito.")
    else:
        print("❌ No se encontraron columnas de skills en el dataset para graficar.")

# ==============================================================================
# GRÁFICO 2: COMPARATIVA DE SALARIOS MEDIOS POR ROL (grafico_salarios.png)
# ==============================================================================
def generar_grafico_salarios(df):
    plt.figure(figsize=(10, 6))
    
    # Calcular mediana salarial agrupada por rol (más robusta que la media ante outliers)
    salario_por_rol = df.groupby('title')['salary'].median().sort_values(ascending=False)
    
    # Gráfico de barras horizontales
    sns.barplot(x=salario_por_rol.values, y=salario_por_rol.index, palette="Oranges_r")
    
    plt.title("Mediana Salarial Anual por Rol de Datos en España", pad=15)
    plt.xlabel("Salario Bruto Anual (€)")
    plt.ylabel("Puesto / Rol")
    
    # Añadir las etiquetas de valor monetario
    for idx, value in enumerate(salario_por_rol.values):
        plt.text(value - 4000, idx, f"{value:,.0f} €", va='center', ha='right', fontweight='bold', color="white")
        
    plt.tight_layout()
    plt.savefig("../images/grafico_salarios.png", dpi=300)
    print("💾 Gráfico 'grafico_salarios.png' guardado con éxito.")

# ==============================================================================
# GRÁFICO 3: MODALIDAD DE TRABAJO (remoto_vs_presencial.png)
# ==============================================================================
def generar_grafico_modalidad(df):
    if 'remote_modality' in df.columns:
        plt.figure(figsize=(8, 6))
        
        # Conteo y distribución porcentual
        modalidad_dist = df['remote_modality'].value_counts(normalize=True) * 100
        
        # Gráfico circular (Donut Chart) elegante
        colors = ["#2B6CB0", "#4299E1", "#ED8936"]
        plt.pie(modalidad_dist.values, labels=modalidad_dist.index, autopct='%1.1f%%', 
                startangle=90, colors=colors, wedgeprops=dict(width=0.4, edgecolor='w'))
        
        plt.title("Distribución de Modalidad de Trabajo (Flexibilidad)", pad=20)
        plt.tight_layout()
        plt.savefig("../images/remoto_vs_presencial.png", dpi=300)
        print("💾 Gráfico 'remoto_vs_presencial.png' guardado con éxito.")
    else:
        print("❌ No se encontró la columna de modalidad de trabajo ('remote_modality') en el dataset.")

# ==============================================================================
# FLUJO PRINCIPAL DE EJECUCIÓN 
# ==============================================================================
if __name__ == "__main__":
    print("🚀 Iniciando motor de visualización para DataTalent Solutions S.L.")
    df_clean = cargar_datos()
    asegurar_carpeta_imagenes()
    
    # Ejecutar generación de gráficos
    generar_grafico_skills(df_clean)
    generar_grafico_salarios(df_clean)
    generar_grafico_modalidad(df_clean)
    
    print("\n🎉 ¡Proceso finalizado, Yohana! Todos tus gráficos base están listos y exportados a la carpeta 'images/'.")
